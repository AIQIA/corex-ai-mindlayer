{
  "AIM Root Compass": {
    "prefix": "ai-root",
    "body": [
      "{",
      "  \"$schema\": \"./vscode-extension/src/schemas/ai.schema.json\",",
      "  \"_meta\": {",
      "    \"version\": \"1.0.0\",",
      "    \"last_updated\": \"${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}\"",
      "  },",
      "  \"project\": {",
      "    \"name\": \"${1:Project Name}\",",
      "    \"description\": \"${2:Description}\",",
      "    \"tech_stack\": [\"${3:PHP}\", \"${4:MySQL}\"]",
      "  },",
      "  \"red_lines\": [",
      "    \"${5:Strict rule 1}\"",
      "  ],",
      "  \"workflow\": {},",
      "  \"architecture\": {},",
      "  \"reference_docs\": [\"README.md\"]",
      "}"
    ],
    "description": "New AIM Root Template"
  },
  "AIM Feature Index": {
    "prefix": "ai-index",
    "body": [
      "{",
      "  \"$schema\": \"./vscode-extension/src/schemas/ai.features.index.schema.json\",",
      "  \"areas\": {",
      "    \"${1:admin}\": {",
      "      \"summary\": \"${2:Admin interface and logic}\",",
      "      \"details\": \".ai.features.${1:admin}.details.json\",",
      "      \"priority\": \"medium\"",
      "    }",
      "  }",
      "}"
    ],
    "description": "New AIM Feature Index Template"
  },
  "AIM Feature Details": {
    "prefix": "ai-details",
    "body": [
      "{",
      "  \"$schema\": \"./vscode-extension/src/schemas/ai.features.details.schema.json\",",
      "  \"_meta\": {",
      "    \"area\": \"${1:area_name}\",",
      "    \"last_updated\": \"${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}\",",
      "    \"priority\": \"medium\"",
      "  },",
      "  \"sections\": {",
      "    \"routes\": [],",
      "    \"files\": [],",
      "    \"truths\": []",
      "  }",
      "}"
    ],
    "description": "New AIM Feature Details Template"
  }
}
