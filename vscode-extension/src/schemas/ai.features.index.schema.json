{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "coreX AI MindLayer - Feature Index",
  "type": "object",
  "required": ["areas"],
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "last_updated": { "type": "string", "format": "date" }
      }
    },
    "areas": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["summary", "details"],
        "properties": {
          "summary": { "type": "string" },
          "details": { "type": "string" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    }
  }
}
